---
import { site, nav } from "../config";
import { buttonVariants } from "@notifro/ui/components/button";
import GithubMark from "./GithubMark.astro";
import Logo from "./Logo.astro";
---

<header class="sticky top-0 z-50 w-full border-b bg-background/80 backdrop-blur supports-[backdrop-filter]:bg-background/60">
  <div class="mx-auto flex h-14 max-w-6xl items-center justify-between px-6">
    <a href="/" class="flex items-center gap-2 font-semibold tracking-tight text-foreground">
      <Logo />
      {site.name}
    </a>

    <nav class="hidden items-center gap-7 md:flex">
      {nav.map((item) => (
        <a href={item.href} class="text-sm font-medium text-muted-foreground transition-colors hover:text-foreground">{item.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-2">
      <a href={site.repoUrl} target="_blank" rel="noopener" class={`${buttonVariants({ variant: "ghost", size: "sm" })} hidden gap-1.5 sm:inline-flex`}>
        <GithubMark class="size-4" /> Open source
      </a>
      <a href={site.selfHostUrl} class={buttonVariants({ size: "sm" })}>Self-host</a>
    </div>
  </div>
</header>
