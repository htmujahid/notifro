---
import { site } from "../config";
import Logo from "./Logo.astro";
const year = 2026;

const cols = [
  {
    title: "Product",
    links: [
      ["Features", "/features"],
      ["Channels", "/channels"],
      ["MCP Server", "/mcp"],
      ["Self-host", "/self-host"],
    ],
  },
  {
    title: "Developers",
    links: [
      ["Documentation", "/developers"],
      ["REST API", "/developers#api"],
      ["SDK & CLI", "/developers#sdks"],
      ["MCP tools", "/mcp"],
      ["GitHub", site.repoUrl],
      ["Status", "/status"],
    ],
  },
  {
    title: "Company",
    links: [
      ["About", "/about"],
      ["Security", "/security"],
      ["Contact", "/contact"],
      ["Blog", "/blog"],
    ],
  },
  {
    title: "Legal",
    links: [
      ["Privacy", "/privacy"],
      ["Terms", "/terms"],
      ["DPA", "/dpa"],
      ["Compliance", "/security"],
    ],
  },
];
---

<footer class="border-t bg-muted/30">
  <div class="mx-auto max-w-6xl px-6 py-14">
    <div class="grid gap-10 md:grid-cols-5">
      <div class="md:col-span-1">
        <a href="/" class="flex items-center gap-2 font-semibold tracking-tight text-foreground">
          <Logo />
          {site.name}
        </a>
        <p class="mt-3 max-w-xs text-sm text-muted-foreground">
          {site.tagline} Unified notification infrastructure with a native MCP server for AI agents.
        </p>
      </div>

      {cols.map((col) => (
        <div>
          <h4 class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">{col.title}</h4>
          <ul class="mt-4 space-y-2.5">
            {col.links.map(([label, href]) => (
              <li>
                <a
                  href={href}
                  {...(href.startsWith("http") ? { target: "_blank", rel: "noopener" } : {})}
                  class="text-sm text-muted-foreground transition-colors hover:text-foreground"
                >{label}</a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <div class="mt-12 flex flex-col gap-2 border-t pt-6 text-sm text-muted-foreground sm:flex-row sm:items-center sm:justify-between">
      <span>© {year} {site.name}, Inc. All rights reserved.</span>
      <span>Encrypted at rest · PII redaction · Self-hostable on Cloudflare</span>
    </div>
  </div>
</footer>
