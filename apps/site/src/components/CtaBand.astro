---
import { site } from "../config";
import { buttonVariants } from "@workspace/ui/components/button";
interface Props {
  title?: string;
  text?: string;
}
const {
  title = "Stop stitching together five notification tools",
  text = "Compose once, deliver everywhere, and let your agents send safely. Start free — no credit card required.",
} = Astro.props;
---

<section class="py-20">
  <div class="mx-auto max-w-6xl px-6">
    <div class="rounded-xl border bg-muted/40 px-6 py-14 text-center sm:px-12">
      <h2 class="mx-auto max-w-2xl text-3xl font-semibold tracking-tight">{title}</h2>
      <p class="mx-auto mt-3 max-w-xl text-muted-foreground">{text}</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href={site.signupUrl} class={buttonVariants({ size: "lg" })}>Start free</a>
        <a href="/contact" class={buttonVariants({ variant: "outline", size: "lg" })}>Talk to sales</a>
      </div>
    </div>
  </div>
</section>
