---
import { site } from "../config";
import { buttonVariants } from "@notifro/ui/components/button";
import GithubMark from "./GithubMark.astro";
interface Props {
  title?: string;
  text?: string;
}
const {
  title = "Own your entire notification stack",
  text = "Compose once, deliver everywhere, and let your agents send safely, open source and self-hosted on your own Cloudflare account.",
} = Astro.props;
---

<section class="py-20">
  <div class="mx-auto max-w-6xl px-6">
    <div class="rounded-xl border bg-muted/40 px-6 py-14 text-center sm:px-12">
      <h2 class="mx-auto max-w-2xl text-3xl font-semibold tracking-tight">{title}</h2>
      <p class="mx-auto mt-3 max-w-xl text-muted-foreground">{text}</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href={site.selfHostUrl} class={buttonVariants({ size: "lg" })}>Self-host on Cloudflare</a>
        <a href={site.repoUrl} target="_blank" rel="noopener" class={`${buttonVariants({ variant: "outline", size: "lg" })} gap-1.5`}>
          <GithubMark class="size-4" /> View on GitHub
        </a>
      </div>
    </div>
  </div>
</section>
