---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../config";
import { buttonVariants } from "@workspace/ui/components/button";

const quickLinks = [
  ["Features", "/features"],
  ["Channels", "/channels"],
  ["MCP Server", "/mcp"],
  ["Developers", "/developers"],
  ["Status", "/status"],
];
---

<BaseLayout title="Page not found" noindex={true}>
  <section class="relative isolate overflow-hidden">
    {/* dotted backdrop + radial fade, same language as the hero */}
    <div class="pointer-events-none absolute inset-0 -z-10 bg-dots mask-radial opacity-60"></div>
    {/* primary glow */}
    <div class="pointer-events-none absolute left-1/2 top-8 -z-10 h-80 w-[46rem] -translate-x-1/2 rounded-full bg-primary/15 blur-[120px]"></div>

    <div class="mx-auto flex min-h-[82svh] max-w-3xl flex-col items-center justify-center px-6 py-24 text-center">
      {/* animated status badge */}
      <span class="inline-flex items-center gap-2 rounded-full border bg-background/70 px-3 py-1 text-xs font-medium text-muted-foreground backdrop-blur">
        <span class="relative flex size-2">
          <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary/60"></span>
          <span class="relative inline-flex size-2 rounded-full bg-primary"></span>
        </span>
        Status 404 · Undeliverable
      </span>

      {/* mega gradient number */}
      <h1 class="mt-8 select-none bg-gradient-to-br from-primary via-sky-500 to-indigo-500 bg-clip-text text-[6rem] font-bold leading-[0.82] tracking-tighter text-transparent sm:text-[11rem]">
        404
      </h1>

      <h2 class="mt-6 text-2xl font-semibold tracking-tight text-foreground sm:text-3xl">
        This page didn't deliver
      </h2>
      <p class="mt-3 max-w-md text-pretty text-muted-foreground">
        The route you requested bounced back undeliverable — no retries, no fallback. But every page
        below is live and routing fine.
      </p>

      <div class="mt-8 flex flex-wrap items-center justify-center gap-3">
        <a href="/" class={buttonVariants({ size: "lg" })}>Back home</a>
        <a href={site.docsUrl} class={buttonVariants({ variant: "outline", size: "lg" })}>Read the docs</a>
      </div>

      {/* quick links */}
      <nav class="mt-12 flex flex-wrap items-center justify-center gap-x-6 gap-y-2 text-sm text-muted-foreground">
        {quickLinks.map(([label, href]) => (
          <a href={href} class="transition-colors hover:text-foreground">{label}</a>
        ))}
      </nav>
    </div>
  </section>
</BaseLayout>
