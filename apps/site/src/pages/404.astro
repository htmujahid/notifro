---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../config";
import { buttonVariants } from "@workspace/ui/components/button";
---

<BaseLayout title="Page not found">
  <section class="mx-auto flex min-h-[60svh] max-w-6xl flex-col items-center justify-center px-6 text-center">
    <p class="text-sm font-semibold text-primary">404</p>
    <h1 class="mt-2 text-4xl font-semibold tracking-tight">This page didn't deliver</h1>
    <p class="mt-3 max-w-md text-muted-foreground">
      The page you're looking for doesn't exist — but your notifications still will.
    </p>
    <div class="mt-7 flex flex-wrap justify-center gap-3">
      <a href="/" class={buttonVariants({ size: "lg" })}>Back home</a>
      <a href="/developers" class={buttonVariants({ variant: "outline", size: "lg" })}>Read the docs</a>
    </div>
  </section>
</BaseLayout>
