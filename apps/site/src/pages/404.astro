---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../config";
---

<BaseLayout title="Page not found">
  <section class="hero" style="min-height:50vh;display:flex;align-items:center">
    <div class="container">
      <span class="eyebrow">404</span>
      <h1>This page didn't deliver</h1>
      <p class="lead mx-auto">The page you're looking for doesn't exist — but your notifications still will.</p>
      <div class="hero-actions">
        <a class="btn btn-primary btn-lg" href="/">Back home</a>
        <a class="btn btn-ghost btn-lg" href="/developers">Read the docs</a>
      </div>
    </div>
  </section>
</BaseLayout>
