---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";

const systems = [
  "Compose & send API",
  "MCP server",
  "Delivery queue & retries",
  "Email / SMTP delivery",
  "Web push & in-app inbox",
  "Webhooks & receipts",
  "Dashboard & analytics",
];
---

<BaseLayout title="Status" description="Notifro system status and uptime.">
  <PageHeader eyebrow="Status" title="All systems operational" lead="Real-time delivery health across every channel." />

  <section class="py-16">
    <div class="mx-auto max-w-2xl px-6">
      <div class="overflow-hidden rounded-xl border bg-card">
        {systems.map((name, i) => (
          <div class={`flex items-center justify-between px-5 py-4 ${i > 0 ? "border-t" : ""}`}>
            <span class="font-medium">{name}</span>
            <span class="inline-flex items-center gap-2 text-sm font-medium text-green-600 dark:text-green-500">
              <span class="size-2 rounded-full bg-green-500"></span>Operational
            </span>
          </div>
        ))}
      </div>
      <p class="mt-5 text-center text-sm text-muted-foreground">99.99% delivery uptime over the trailing 90 days.</p>
    </div>
  </section>
</BaseLayout>
