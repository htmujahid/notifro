---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
const updated = "June 20, 2026";
const prose =
  "mx-auto max-w-2xl px-6 py-16 text-muted-foreground [&_h2]:mt-10 [&_h2]:text-xl [&_h2]:font-semibold [&_h2]:tracking-tight [&_h2]:text-foreground [&_p]:mt-4 [&_ul]:mt-4 [&_ul]:list-disc [&_ul]:pl-5 [&_li]:mt-2 [&_a]:text-primary [&_a]:underline-offset-4 hover:[&_a]:underline";
---

<BaseLayout title="Privacy Policy" description="How Notifro collects, uses, and protects data.">
  <PageHeader eyebrow="Legal" title="Privacy Policy" lead={`Last updated ${updated}`} />

  <div class={prose}>
    <p>This Privacy Policy explains how Notifro, Inc. (“Notifro”, “we”) collects, uses, and
    protects information when you use our notification infrastructure and MCP server. This page is
    a product template and not legal advice; consult counsel before publishing.</p>

    <h2>Information we collect</h2>
    <ul>
      <li><b class="text-foreground">Account data</b> — name, email, and organization details you provide.</li>
      <li><b class="text-foreground">Recipient & message data</b> — content and metadata you send on behalf of your end users.</li>
      <li><b class="text-foreground">Connected accounts</b> — OAuth tokens and granted scopes for the providers you connect, stored encrypted.</li>
      <li><b class="text-foreground">Usage & delivery logs</b> — delivery status, engagement events, and API request metadata.</li>
    </ul>

    <h2>How we use information</h2>
    <ul>
      <li>To deliver, schedule, and route notifications across channels.</li>
      <li>To provide analytics, delivery tracking, and audit logs.</li>
      <li>To maintain security, prevent abuse, and enforce scope-based permissions.</li>
      <li>To operate, support, and improve the service.</li>
    </ul>

    <h2>Data processing & sub-processors</h2>
    <p>We act as a data processor for the recipient and message data you send. We use vetted
    sub-processors (e.g. cloud hosting and delivery providers) under a Data Processing Addendum. A
    current list is available on request.</p>

    <h2>Data retention</h2>
    <p>Message content and logs are retained according to your configuration, and can be redacted or
    deleted on request. Self-hosting on your own Cloudflare account keeps all data in your control.</p>

    <h2>Your rights</h2>
    <p>Subject to applicable law (including GDPR and CAN-SPAM), you may request access, correction,
    deletion, or export of personal data. You are responsible for honouring the consent and
    unsubscribe obligations of the recipients you send to.</p>

    <h2>Security</h2>
    <p>We employ encryption in transit and at rest, AES-GCM encrypted channel credentials, scoped
    API keys, and PII redaction. See our <a href="/security">Security page</a> for details.</p>

    <h2>Contact</h2>
    <p>Questions about this policy? Email <a href="mailto:privacy@notifro.com">privacy@notifro.com</a>.</p>
  </div>
</BaseLayout>
