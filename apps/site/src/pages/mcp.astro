---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import CtaBand from "../components/CtaBand.astro";
import { site } from "../config";
import { buttonVariants } from "@workspace/ui/components/button";
import { Brain, ShieldCheck, Hand, Check } from "lucide-react";

const tools = [
  ["send_notification", "Compose and deliver across one or more channels. Checks approval gates before sending."],
  ["schedule_notification", "Set a future send-at time for timezone-aware scheduled delivery."],
  ["list_channels", "Discover connected and healthy channels."],
  ["get_delivery_status", "Query queued / sent / delivered / failed state for a notification."],
  ["manage_preferences", "Read and update recipient channel and topic preferences."],
  ["create_template", "Build a template with variables, conditionals, and localization."],
  ["render_preview", "Preview a template rendered per channel before sending."],
  ["query_analytics", "Pull delivery, engagement, and cost metrics."],
  ["approve_action", "Approve or reject a pending MCP action that required human sign-off."],
];

const standout = [
  { icon: Brain, title: "Agentic sending", text: "An agent decides what to send, which channel, and when — your routing and fallback logic runs underneath, consistent with API and UI sends." },
  { icon: ShieldCheck, title: "API-key scoped safety", text: "The server enforces the same API-key permissions you granted. Agents act only within those boundaries — no broader access than the key allows." },
  { icon: Hand, title: "Human-in-the-loop", text: "Preview-before-send and approval-gate tools prevent agents from blasting messages unchecked. Nothing ships without your guardrails." },
  { icon: ShieldCheck, title: "Rate-limited and idempotent", text: "KV-backed rate limiting at the MCP layer prevents agent loops from duplicating sends or running away. Every call is audited." },
];

const resources = [
  ["Channels", "Connected channels and their current health (renderical://channels)"],
  ["Templates", "Available templates and their variable schemas (renderical://templates)"],
  ["Recent deliveries", "Last 20 deliveries for delivery-status context (renderical://recent-deliveries)"],
];

const prompts = [
  ["send-notification-help", "How do I send a notification across channels with fallback?"],
  ["check-delivery-status", "Check delivery status for recent notifications."],
  ["setup-approval-gates", "Help me set up approval gates for agent sends."],
];
---

<BaseLayout title="MCP Server" description="Expose your notification infrastructure as an MCP server so AI agents can compose, schedule, and deliver — API-key authenticated, with approval gates, rate limiting, and full audit.">
  <PageHeader
    eyebrow="MCP server layer"
    title="Your notification stack, as an MCP server"
    lead="Let Claude, IDE assistants, and custom agents compose, schedule, and deliver notifications in natural language — using your routing, fallback, and rate-limiting logic underneath. No manual API wiring."
  />

  <!-- Standout -->
  <section class="py-16">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-5 sm:grid-cols-2">
        {standout.map((s) => (
          <div class="rounded-xl border bg-card p-6">
            <div class="flex size-9 items-center justify-center rounded-lg border bg-muted/50">
              <s.icon className="size-5" />
            </div>
            <h3 class="mt-4 font-semibold">{s.title}</h3>
            <p class="mt-1.5 text-sm text-muted-foreground">{s.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Tools -->
  <section class="border-t bg-muted/30 py-16">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-semibold tracking-tight">Tools exposed to agents</h2>
        <p class="mt-3 text-muted-foreground">Every core capability is a first-class tool an agent can call.</p>
      </div>
      <div class="mt-10 grid gap-4 sm:grid-cols-2">
        {tools.map(([name, desc]) => (
          <div class="rounded-xl border bg-card p-5">
            <code class="text-sm font-semibold text-primary">{name}</code>
            <p class="mt-1.5 text-sm text-muted-foreground">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Resources & prompts -->
  <section class="py-16">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <div>
          <p class="text-sm font-semibold text-primary">MCP resources</p>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight">Read-context for agents</h2>
          <p class="mt-3 text-muted-foreground">Agents ground their decisions in live context exposed as MCP resources.</p>
          <ul class="mt-5 space-y-3 text-sm">
            {resources.map(([t, d]) => (
              <li class="flex gap-3"><Check className="mt-0.5 size-4 shrink-0 text-primary" /><span><span class="font-medium text-foreground">{t}</span> — {d}</span></li>
            ))}
          </ul>
        </div>
        <div>
          <p class="text-sm font-semibold text-primary">MCP prompts</p>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight">Reusable workflows</h2>
          <p class="mt-3 text-muted-foreground">Ship guided, repeatable agent workflows out of the box.</p>
          <ul class="mt-5 space-y-3 text-sm">
            {prompts.map(([t, d]) => (
              <li class="flex gap-3"><Check className="mt-0.5 size-4 shrink-0 text-primary" /><span><span class="font-medium text-foreground">{t}</span> — {d}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Deployment -->
  <section class="border-t bg-muted/30 py-16">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-semibold tracking-tight">Remote and local, same guarantees</h2>
      </div>
      <div class="mt-10 grid gap-5 sm:grid-cols-3">
        <div class="rounded-xl border bg-card p-6">
          <h3 class="font-semibold">Remote MCP</h3>
          <p class="mt-1.5 text-sm text-muted-foreground">Hosted on Cloudflare Workers, API-key authenticated — connect from Claude, any MCP client, or IDE assistant.</p>
        </div>
        <div class="rounded-xl border bg-card p-6">
          <h3 class="font-semibold">Local / stdio MCP</h3>
          <p class="mt-1.5 text-sm text-muted-foreground">Run locally for self-hosted and dev setups, with the same per-tool scope enforcement.</p>
        </div>
        <div class="rounded-xl border bg-card p-6">
          <h3 class="font-semibold">Safe by default</h3>
          <p class="mt-1.5 text-sm text-muted-foreground">Rate limiting and idempotency at the MCP layer — agent loops can't duplicate or run away. Every send is audited.</p>
        </div>
      </div>
      <div class="mt-10 text-center">
        <a href="/developers" class={buttonVariants()}>Connect the server</a>
      </div>
    </div>
  </section>

  <CtaBand
    title="Give your agents a safe way to notify"
    text="Connect the Renderical MCP server and let agents send with your API key — fully audited, rate-limited, and preview-gated."
  />
</BaseLayout>
