---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import CtaBand from "../components/CtaBand.astro";

const values = [
  ["Compose once", "Developers should write a message a single time, not once per channel. Abstraction is the product."],
  ["Safe by default", "Idempotency, scopes, rate limits, and approval gates are on from day one, not bolted on later."],
  ["Agent-ready", "Notifications are increasingly sent by AI. We make that safe, scoped, and auditable."],
  ["Own your data", "Encrypted credentials, PII redaction, and a self-hosted Cloudflare option keep you in control."],
];
---

<BaseLayout title="About" description="Notifro is the unified notification infrastructure that replaces the five-tool stack teams stitch together, built for the agentic era.">
  <PageHeader
    eyebrow="About"
    title="One layer for every notification"
    lead="Teams stitch together five or more tools to reach users across Slack, email, push, and chat. Notifro replaces that stack with a single compose-once API, and a native MCP server so AI agents can send safely."
  />

  <section class="py-16">
    <div class="mx-auto max-w-2xl px-6">
      <p class="text-lg text-muted-foreground">
        We started Notifro after rebuilding the same notification plumbing at company after
        company: a Slack integration here, an email service there, a push provider, a preference
        center nobody wanted to maintain, and brittle glue code holding it all together.
      </p>
      <p class="mt-4 text-lg text-muted-foreground">
        Notifro normalizes all of it behind one payload. You compose a message once; we
        transform and deliver it per channel, handle routing, fallback, and retries, respect
        quiet hours and rate limits, and give your agents a scoped, audited way to send.
      </p>
    </div>
  </section>

  <section class="border-t bg-muted/30 py-16">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-sm font-semibold text-primary">What we believe</p>
        <h2 class="mt-2 text-3xl font-semibold tracking-tight">Principles behind the product</h2>
      </div>
      <div class="mt-10 grid gap-5 sm:grid-cols-2">
        {values.map(([t, d]) => (
          <div class="rounded-xl border bg-card p-6">
            <h3 class="font-semibold">{t}</h3>
            <p class="mt-1.5 text-sm text-muted-foreground">{d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaBand title="Build on Notifro" />
</BaseLayout>
