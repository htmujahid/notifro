---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaBand from "../components/CtaBand.astro";

const channels = [
  { name: "Slack", color: "#4a154b", icon: "💬", transform: "Block Kit", note: "Interactive blocks, buttons, and threaded updates." },
  { name: "Gmail / SMTP", color: "#ea4335", icon: "✉️", transform: "Responsive HTML", note: "Branded, responsive HTML email with any SMTP provider." },
  { name: "Microsoft Teams", color: "#6264a7", icon: "👥", transform: "Adaptive Cards", note: "Rich adaptive cards with actions and inputs." },
  { name: "Discord", color: "#5865f2", icon: "🎮", transform: "Embeds", note: "Rich embeds, components, and webhook delivery." },
  { name: "Mobile Push", color: "#34c759", icon: "📱", transform: "APNs / FCM", note: "Native iOS and Android push with rich payloads." },
  { name: "Web Push", color: "#f59e0b", icon: "🌐", transform: "Service Worker", note: "Browser push via the standard Web Push protocol." },
  { name: "In-App Inbox", color: "#5b54f0", icon: "🔔", transform: "Drop-in feed", note: "Embeddable notification feed with read state." },
  { name: "Webhooks", color: "#0ea5e9", icon: "🪝", transform: "Signed JSON", note: "Generic signed webhooks with replay protection." },
  { name: "SMS", color: "#ec4899", icon: "📨", transform: "Plain text", note: "Reliable fallback tier across major SMS providers." },
];
---

<BaseLayout title="Channels" description="Slack, Gmail/SMTP, Microsoft Teams, Discord, mobile & web push, in-app inbox, webhooks, and SMS — one compose-once API, automatically transformed per channel.">
  <section class="hero" style="padding-bottom:48px">
    <div class="container">
      <span class="eyebrow">Channels</span>
      <h1>Every channel, one integration</h1>
      <p class="lead mx-auto">Write your message once. {`Renderical`} transforms it into the
      native format each destination expects and delivers with rate-aware throttling.</p>
    </div>
  </section>

  <section style="padding-top:24px">
    <div class="container">
      <div class="grid grid-3">
        {channels.map((c) => (
          <div class="card">
            <div class="card-icon" style={`background:${c.color}1a;border-color:${c.color}33`}>{c.icon}</div>
            <h3>{c.name}</h3>
            <p style="margin-bottom:14px">{c.note}</p>
            <span class="pill">Renders to {c.transform}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="band-dark">
    <div class="container">
      <div class="split">
        <div>
          <span class="eyebrow">Routing & fallback</span>
          <h2>Smart routing across channels</h2>
          <p>Define ordered fallback chains and routing rules so the right channel is always
          tried first — and a backup always catches what doesn't land.</p>
          <ul class="checklist" style="margin-top:18px">
            <li><span class="tick">✓</span><span>Fallback chains: <b>push → email → SMS</b></span></li>
            <li><span class="tick">✓</span><span>Route by <b>user, message type, priority, or time</b></span></li>
            <li><span class="tick">✓</span><span>Per-recipient <b>channel priority ordering</b></span></li>
            <li><span class="tick">✓</span><span>Quiet hours, DND windows, and time-window delivery</span></li>
          </ul>
        </div>
        <div class="split-media">
          <div class="code">
            <div class="code-head"><span></span><span></span><span></span></div>
            <span class="c-key">fallback</span>: [<br />
            &nbsp;&nbsp;&#123; channel: <span class="c-str">"push"</span>, timeout: <span class="c-str">"30s"</span> &#125;,<br />
            &nbsp;&nbsp;&#123; channel: <span class="c-str">"email"</span>, timeout: <span class="c-str">"10m"</span> &#125;,<br />
            &nbsp;&nbsp;&#123; channel: <span class="c-str">"sms"</span> &#125;,<br />
            ],<br />
            <span class="c-key">rules</span>: [<br />
            &nbsp;&nbsp;&#123; if: <span class="c-str">"priority == high"</span>,<br />
            &nbsp;&nbsp;&nbsp;&nbsp;then: <span class="c-str">"slack,push"</span> &#125;,<br />
            ]
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBand title="Connect your first channel in minutes" />
</BaseLayout>
