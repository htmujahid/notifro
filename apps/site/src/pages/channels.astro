---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import CtaBand from "../components/CtaBand.astro";
import {
  MessageSquare,
  Mail,
  Users,
  Gamepad2,
  Globe,
  Bell,
  Webhook,
  MessageCircle,
  Phone,
  Send,
  Check,
} from "lucide-react";

const channels = [
  { name: "Slack", icon: MessageSquare, transform: "Block Kit", note: "Interactive blocks, buttons, and threaded updates." },
  { name: "Gmail / SMTP", icon: Mail, transform: "Responsive HTML", note: "Branded, responsive HTML email with any SMTP provider." },
  { name: "Microsoft Teams", icon: Users, transform: "Adaptive Cards", note: "Rich adaptive cards with actions and inputs." },
  { name: "Discord", icon: Gamepad2, transform: "Embeds", note: "Rich embeds, components, and webhook delivery." },
  { name: "Web Push", icon: Globe, transform: "VAPID / Service Worker", note: "Browser push via the standard Web Push protocol, encrypted per spec." },
  { name: "In-App Inbox", icon: Bell, transform: "Drop-in feed", note: "Embeddable notification feed with read state." },
  { name: "Webhooks", icon: Webhook, transform: "Signed JSON", note: "Generic signed webhooks with replay protection." },
  { name: "SMS", icon: MessageCircle, transform: "Plain text", note: "Reliable fallback tier across major SMS providers." },
  { name: "WhatsApp", icon: Phone, transform: "Template messages", note: "Reach users on WhatsApp with rich template messages via Twilio." },
  { name: "Telegram", icon: Send, transform: "Bot messages", note: "Deliver messages to users and groups via a Telegram bot token." },
];
---

<BaseLayout title="Channels" description="Slack, email/SMTP, Microsoft Teams, Discord, web push, in-app inbox, webhooks, SMS, WhatsApp, and Telegram — one compose-once API, automatically transformed per channel.">
  <PageHeader
    eyebrow="Channels"
    title="Every channel, one integration"
    lead="Write your message once. Renderical transforms it into the native format each destination expects and delivers with rate-aware throttling."
  />

  <section class="py-16">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {channels.map((c) => (
          <div class="rounded-xl border bg-card p-6">
            <div class="flex size-9 items-center justify-center rounded-lg border bg-muted/50">
              <c.icon className="size-5" />
            </div>
            <h3 class="mt-4 font-semibold">{c.name}</h3>
            <p class="mt-1.5 text-sm text-muted-foreground">{c.note}</p>
            <span class="mt-4 inline-block rounded-md bg-muted px-2.5 py-1 text-xs font-medium text-muted-foreground">Renders to {c.transform}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="border-t bg-muted/30 py-16">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <p class="text-sm font-semibold text-primary">Routing & fallback</p>
          <h2 class="mt-2 text-3xl font-semibold tracking-tight">Smart routing across channels</h2>
          <p class="mt-4 text-muted-foreground">
            Define ordered fallback chains and routing rules so the right channel is always tried
            first — and a backup always catches what doesn't land.
          </p>
          <ul class="mt-6 space-y-3 text-sm">
            <li class="flex gap-3"><Check className="mt-0.5 size-4 shrink-0 text-primary" /><span>Fallback chains: <span class="font-medium text-foreground">push → email → SMS</span></span></li>
            <li class="flex gap-3"><Check className="mt-0.5 size-4 shrink-0 text-primary" /><span>Route by <span class="font-medium text-foreground">user, message type, priority, or time</span></span></li>
            <li class="flex gap-3"><Check className="mt-0.5 size-4 shrink-0 text-primary" /><span>Per-recipient <span class="font-medium text-foreground">channel priority ordering</span></span></li>
            <li class="flex gap-3"><Check className="mt-0.5 size-4 shrink-0 text-primary" /><span>Quiet hours, DND windows, and time-window delivery</span></li>
          </ul>
        </div>
        <div class="rounded-xl border bg-card p-5 font-mono text-sm leading-relaxed">
          <pre class="overflow-x-auto text-muted-foreground"><code>fallback: [
  {'{'} channel: <span class="text-primary">"push"</span>, timeout: <span class="text-primary">"30s"</span> {'}'},
  {'{'} channel: <span class="text-primary">"email"</span>, timeout: <span class="text-primary">"10m"</span> {'}'},
  {'{'} channel: <span class="text-primary">"sms"</span> {'}'},
],
rules: [
  {'{'} if: <span class="text-primary">"priority == high"</span>,
    then: <span class="text-primary">"slack,push"</span> {'}'},
  {'{'} if: <span class="text-primary">"messageType == transactional"</span>,
    then: <span class="text-primary">"email"</span> {'}'},
]</code></pre>
        </div>
      </div>
    </div>
  </section>

  <CtaBand title="Connect your first channel in minutes" />
</BaseLayout>
