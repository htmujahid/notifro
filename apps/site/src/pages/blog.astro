---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import { site } from "../config";

const posts = [
  ["Why we built a compose-once notification API", "The case against per-channel branching, and how one normalized payload changes how teams ship.", "Engineering"],
  ["Designing a safe MCP server for agentic sending", "Scope enforcement, preview gates, idempotency, and audit — how agents send without going rogue.", "Product"],
  ["Fallback chains that actually reach people", "Push → email → SMS done right: timeouts, dedup, and respecting quiet hours.", "Engineering"],
];
---

<BaseLayout title="Blog" description="Notes on notifications, delivery, and the agentic era from the Notifro team.">
  <PageHeader eyebrow="Blog" title="From the Notifro team" lead="Notes on notifications, delivery infrastructure, and building for agents." />

  <section class="py-16">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {posts.map(([t, d, tag]) => (
          <article class="rounded-xl border bg-card p-6">
            <span class="rounded-md bg-muted px-2.5 py-1 text-xs font-medium text-muted-foreground">{tag}</span>
            <h3 class="mt-4 font-semibold">{t}</h3>
            <p class="mt-1.5 text-sm text-muted-foreground">{d}</p>
          </article>
        ))}
      </div>
      <p class="mt-10 text-center text-sm text-muted-foreground">
        Want updates? Email <a href={`mailto:${site.email}`} class="text-primary underline-offset-4 hover:underline">{site.email}</a>.
      </p>
    </div>
  </section>
</BaseLayout>
