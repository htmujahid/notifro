---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";

const entries = [
  { date: "June 2026", tag: "New", title: "Native MCP server (GA)", body: "Compose, schedule, and deliver via MCP tools from Claude and any MCP client — scope-aware, preview-gated, and fully audited. Available hosted (OAuth) and local (stdio)." },
  { date: "May 2026", tag: "New", title: "Send-time optimization", body: "Deliver when each recipient is most likely active, with per-individual prediction and quiet-hours awareness." },
  { date: "April 2026", tag: "Improved", title: "Digest bundling & frequency capping", body: "Roll up N notifications into a single digest and cap how many messages a user receives per window." },
  { date: "March 2026", tag: "New", title: "Microsoft Teams & Discord channels", body: "Adaptive cards for Teams and rich embeds for Discord, both rendered from the same compose-once payload." },
];
---

<BaseLayout title="Changelog" description="What's new in Renderical.">
  <PageHeader eyebrow="Changelog" title="What's new" lead="Product updates, new channels, and improvements." />

  <section class="py-16">
    <div class="mx-auto max-w-2xl px-6">
      <div class="space-y-5">
        {entries.map((e) => (
          <div class="rounded-xl border bg-card p-6">
            <div class="flex items-center gap-2">
              <span class="rounded-md bg-muted px-2.5 py-1 text-xs font-medium text-muted-foreground">{e.date}</span>
              <span class="rounded-md bg-primary/10 px-2.5 py-1 text-xs font-medium text-primary">{e.tag}</span>
            </div>
            <h3 class="mt-3 font-semibold">{e.title}</h3>
            <p class="mt-1.5 text-sm text-muted-foreground">{e.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
