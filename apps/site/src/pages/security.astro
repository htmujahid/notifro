---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaBand from "../components/CtaBand.astro";
import {
  ShieldCheck,
  Lock,
  EyeOff,
  KeyRound,
  Webhook,
  ScrollText,
  Server,
  Globe,
  Check,
  Fingerprint,
  Building2,
  Clock,
  Smartphone,
  Bot,
  Mail,
} from "lucide-react";

const account = [
  { icon: Smartphone, title: "Two-factor authentication", text: "Authenticator-app TOTP, an email-OTP backup, and one-time recovery codes you can regenerate." },
  { icon: Mail, title: "Verified identity", text: "Email verification and phone-number verification (Twilio SMS OTP) before an account is active." },
  { icon: KeyRound, title: "Password & OAuth", text: "Email + password with OTP-based reset, or sign in with Google. Sessions are KV-backed." },
  { icon: ShieldCheck, title: "Account rate limiting", text: "100 requests / 60s per account and a trusted-origins CORS guard, enforced at the edge." },
];

const keys = [
  ["rk_live_8a2…f01", "live", "active"],
  ["rk_test_4c9…b7d", "test", "active"],
  ["rk_live_1e0…a55", "live", "revoked"],
];

const auditFeed = [
  ["agent", "send_notification", "scoped · approved", "2m ago"],
  ["api", "template.update", "v2 → v3", "1h ago"],
  ["api", "connection.create", "slack workspace", "3h ago"],
  ["system", "webhook.signed", "delivery receipt", "5h ago"],
];

const mcpSafety = [
  "Per-tool approval gates, sends can require human sign-off",
  "Agents act only within the granted API key's scope",
  "KV-backed rate limiting stops runaway agent loops",
  "Idempotency keys prevent duplicate sends",
  "Every tool call is written to the request log",
  "Pending actions expire if never approved",
];
---

<BaseLayout title="Security" description="Encrypted credentials, PII redaction, two-factor auth, scoped API keys, signed webhooks, idempotency, audit logging, and a self-hosted option, Notifro's security, exactly as built.">
  <!-- Header -->
  <section class="relative overflow-hidden border-b">
    <div class="pointer-events-none absolute inset-0 bg-dots mask-radial opacity-60"></div>
    <div class="pointer-events-none absolute left-1/2 top-0 h-64 w-[40rem] -translate-x-1/2 rounded-full bg-primary/10 blur-3xl"></div>
    <div class="relative mx-auto max-w-6xl px-6 py-20 text-center">
      <span class="inline-flex items-center gap-2 rounded-full border bg-background/70 px-3 py-1 text-xs font-medium text-muted-foreground backdrop-blur">
        <ShieldCheck className="size-3.5 text-primary" /> Security
      </span>
      <h1 class="mx-auto mt-5 max-w-3xl text-4xl font-semibold tracking-tight text-balance sm:text-5xl">
        Trust built into every send
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-muted-foreground text-pretty">
        Encrypted credentials, PII redaction, two-factor auth, scoped keys, signed webhooks, and a
        self-hosted option, running entirely on Cloudflare's edge. Here's exactly how.
      </p>
    </div>
  </section>

  <!-- Account security -->
  <section class="border-b py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <span class="inline-flex items-center gap-2 rounded-lg border bg-muted/50 px-2.5 py-1 text-xs font-semibold text-muted-foreground"><Fingerprint className="size-3.5" /> Account security</span>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight">Lock down access from day one</h2>
        <p class="mt-3 text-muted-foreground">Multi-factor auth, verified identity, and OAuth, powered by better-auth.</p>
      </div>
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {account.map((a) => (
          <div class="rounded-xl border bg-card p-6">
            <span class="flex size-9 items-center justify-center rounded-lg border bg-muted/50"><a.icon className="size-5" /></span>
            <h3 class="mt-4 font-semibold">{a.title}</h3>
            <p class="mt-1.5 text-sm text-muted-foreground">{a.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Data protection -->
  <section class="border-b bg-muted/30 py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <span class="inline-flex items-center gap-2 rounded-lg border bg-background px-2.5 py-1 text-xs font-semibold text-muted-foreground"><Lock className="size-3.5" /> Data protection</span>
          <h2 class="mt-4 text-3xl font-semibold tracking-tight">Your data, encrypted and minimized</h2>
          <p class="mt-3 text-muted-foreground">Channel credentials are encrypted at rest, and PII is redacted from errors before anything is stored or logged.</p>
          <ul class="mt-6 grid gap-3 text-sm sm:grid-cols-2">
            {[
              "TLS in transit, encrypted at rest",
              "AES-GCM encrypted channel credentials",
              "PII redaction before storage & logs",
              "KV-backed sessions with CORS guard",
            ].map((t) => (
              <li class="flex gap-2.5"><Check className="mt-0.5 size-4 shrink-0 text-primary" /><span class="text-muted-foreground">{t}</span></li>
            ))}
          </ul>
        </div>
        <!-- redaction mock -->
        <div class="overflow-hidden rounded-xl border bg-card">
          <div class="flex items-center justify-between border-b bg-muted/40 px-4 py-3">
            <span class="font-mono text-xs text-muted-foreground">stored error payload</span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-green-500/10 px-2.5 py-1 text-xs font-medium text-green-600 dark:text-green-500"><Lock className="size-3" /> Encrypted at rest</span>
          </div>
          <div class="space-y-2.5 p-5 font-mono text-xs">
            {[
              ["channel", "email", false],
              ["to", "ma•••••@acme.com", true],
              ["phone", "+1 ••• ••• 0142", true],
              ["error", "provider 502 · retry 3/5", false],
              ["template", "invoice.paid", false],
            ].map(([k, v, redacted]) => (
              <div class="flex items-center justify-between gap-3">
                <span class="text-muted-foreground">{k}:</span>
                <span class="flex items-center gap-2">
                  <span class="text-foreground">{v}</span>
                  {redacted && <span class="inline-flex items-center gap-1 rounded bg-muted px-1.5 py-0.5 text-[10px] font-medium text-muted-foreground"><EyeOff className="size-2.5" /> redacted</span>}
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- API keys & access -->
  <section class="border-b py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <!-- api key list mock -->
        <div class="order-2 lg:order-1 overflow-hidden rounded-xl border bg-card text-sm">
          <div class="flex items-center gap-2 border-b bg-muted/40 px-4 py-3 text-sm font-medium"><KeyRound className="size-4 text-primary" /> API keys</div>
          {keys.map(([key, mode, status], i) => (
            <div class={`flex items-center justify-between px-4 py-3 ${i < keys.length - 1 ? "border-b" : ""}`}>
              <code class="font-mono text-xs">{key}</code>
              <span class="flex items-center gap-2">
                <span class={`rounded-full px-2 py-0.5 text-xs font-medium ${mode === "live" ? "bg-primary/10 text-primary" : "bg-muted text-muted-foreground"}`}>{mode}</span>
                <span class={`rounded-full px-2 py-0.5 text-xs font-medium ${status === "active" ? "bg-green-500/10 text-green-600 dark:text-green-500" : "bg-muted text-muted-foreground line-through"}`}>{status}</span>
              </span>
            </div>
          ))}
        </div>
        <div class="order-1 lg:order-2">
          <span class="inline-flex items-center gap-2 rounded-lg border bg-muted/50 px-2.5 py-1 text-xs font-semibold text-muted-foreground"><KeyRound className="size-3.5" /> Keys & access</span>
          <h2 class="mt-4 text-3xl font-semibold tracking-tight">Scoped keys, revocable any time</h2>
          <p class="mt-3 text-muted-foreground">Every request authenticates with a session cookie or an <code class="rounded bg-muted px-1.5 py-0.5 text-sm">rk_</code>-prefixed API key. Keys carry a live/test mode label and per-key rate-limit config, and you can revoke any of them instantly.</p>
          <ul class="mt-6 grid gap-3 text-sm sm:grid-cols-2">
            {["rk_ keys with live & test modes", "Per-key rate-limit configuration", "Bearer or X-API-Key auth", "Instant revocation", "Agents inherit only the key's scope", "Session cookie or key, your choice"].map((t) => (
              <li class="flex gap-2.5"><Check className="mt-0.5 size-4 shrink-0 text-primary" /><span class="text-muted-foreground">{t}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Integrity & audit -->
  <section class="border-b bg-muted/30 py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <span class="inline-flex items-center gap-2 rounded-lg border bg-background px-2.5 py-1 text-xs font-semibold text-muted-foreground"><Fingerprint className="size-3.5" /> Integrity & auditability</span>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight">Provable, tamper-evident, fully logged</h2>
        <p class="mt-3 text-muted-foreground">HMAC-signed outbound webhooks with replay protection, idempotency on every send, and a request log that covers API, UI, and agent activity alike.</p>
      </div>
      <div class="mt-10 grid gap-5 lg:grid-cols-2">
        <!-- signed webhook -->
        <div class="overflow-hidden rounded-xl border bg-card">
          <div class="flex items-center justify-between border-b bg-muted/40 px-4 py-3">
            <span class="flex items-center gap-2 text-sm font-medium"><Webhook className="size-4 text-primary" /> Signed webhook</span>
            <span class="inline-flex items-center gap-1.5 rounded-full bg-green-500/10 px-2.5 py-1 text-xs font-medium text-green-600 dark:text-green-500"><Check className="size-3" /> Verified</span>
          </div>
          <div class="space-y-1 p-5 font-mono text-xs text-muted-foreground">
            <div><span class="text-foreground">POST</span> /your/webhook</div>
            <div>X-Notifro-Signature: <span class="text-primary">t=1718,v1=9f86d0…</span></div>
            <div>X-Notifro-Timestamp: <span class="text-foreground">1718900000</span></div>
            <div class="pt-2 text-muted-foreground/70">// HMAC-SHA256 · replay-safe · idempotent</div>
          </div>
        </div>
        <!-- audit feed -->
        <div class="overflow-hidden rounded-xl border bg-card">
          <div class="flex items-center gap-2 border-b bg-muted/40 px-4 py-3 text-sm font-medium"><ScrollText className="size-4 text-primary" /> API request log</div>
          <div class="divide-y">
            {auditFeed.map(([actor, action, detail, when]) => (
              <div class="flex items-center justify-between gap-3 px-4 py-2.5 text-sm">
                <span class="flex min-w-0 items-center gap-2">
                  <code class="rounded bg-muted px-1.5 py-0.5 text-xs">{actor}</code>
                  <span class="truncate font-medium">{action}</span>
                  <span class="hidden truncate text-xs text-muted-foreground sm:inline">{detail}</span>
                </span>
                <span class="flex shrink-0 items-center gap-1 text-xs text-muted-foreground"><Clock className="size-3" />{when}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- MCP safety -->
  <section class="border-b py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <span class="inline-flex items-center gap-2 rounded-lg border bg-muted/50 px-2.5 py-1 text-xs font-semibold text-muted-foreground"><Bot className="size-3.5" /> Agentic safety</span>
          <h2 class="mt-4 text-3xl font-semibold tracking-tight">Let agents send, within guardrails</h2>
          <p class="mt-3 text-muted-foreground">The MCP server enforces the same key scopes you grant, gates sensitive actions behind human approval, and rate-limits everything so a loop can't run away.</p>
          <ul class="mt-6 grid gap-3 text-sm sm:grid-cols-2">
            {mcpSafety.map((t) => (
              <li class="flex gap-2.5"><Check className="mt-0.5 size-4 shrink-0 text-primary" /><span class="text-muted-foreground">{t}</span></li>
            ))}
          </ul>
        </div>
        <div class="rounded-xl border bg-card p-5 font-mono text-xs leading-relaxed text-muted-foreground">
          <span class="text-muted-foreground/60"># agent calls send_notification</span><br />
          → approval gate: <span class="text-primary">required</span><br />
          → status: <span class="text-foreground">pending</span> · token <span class="text-primary">apr_7f…</span><br /><br />
          <span class="text-muted-foreground/60"># human approves</span><br />
          approve_action(<span class="text-primary">"apr_7f…"</span>)<br />
          → <span class="text-green-600 dark:text-green-500">✓ scope-checked</span><br />
          → <span class="text-green-600 dark:text-green-500">✓ rate-limited</span><br />
          → <span class="text-green-600 dark:text-green-500">✓ logged & sent</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Deployment -->
  <section class="py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <span class="inline-flex items-center gap-2 rounded-lg border bg-muted/50 px-2.5 py-1 text-xs font-semibold text-muted-foreground"><Server className="size-3.5" /> Deployment</span>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight">Run it your way</h2>
        <p class="mt-3 text-muted-foreground">The same compose API and stdio MCP server, hosted on the edge, or in your own Cloudflare account.</p>
      </div>
      <div class="mt-10 grid gap-5 md:grid-cols-2">
        <div class="rounded-xl border bg-card p-6">
          <div class="flex items-center gap-2.5">
            <span class="flex size-9 items-center justify-center rounded-lg border bg-muted/50"><Globe className="size-5" /></span>
            <h3 class="font-semibold">Edge-native on Cloudflare</h3>
          </div>
          <ul class="mt-4 space-y-2.5 text-sm">
            {["Runs on Cloudflare Workers worldwide", "D1 for data, Queues for delivery, KV for sessions", "Provider failover when a connection is down"].map((t) => (
              <li class="flex gap-2.5"><Check className="mt-0.5 size-4 shrink-0 text-primary" /><span class="text-muted-foreground">{t}</span></li>
            ))}
          </ul>
        </div>
        <div class="rounded-xl border bg-card p-6">
          <div class="flex items-center gap-2.5">
            <span class="flex size-9 items-center justify-center rounded-lg border bg-muted/50"><Building2 className="size-5" /></span>
            <h3 class="font-semibold">Self-hosted</h3>
          </div>
          <ul class="mt-4 space-y-2.5 text-sm">
            {["Deploy to your own Cloudflare account", "Full control over your data & credentials", "Run the MCP server as a local stdio binary"].map((t) => (
              <li class="flex gap-2.5"><Check className="mt-0.5 size-4 shrink-0 text-primary" /><span class="text-muted-foreground">{t}</span></li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <CtaBand title="Security questions? We have answers." text="Talk to our team about credentials, redaction, agentic safety, and self-hosted deployment." />
</BaseLayout>
