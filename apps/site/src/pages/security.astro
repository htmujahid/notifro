---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import CtaBand from "../components/CtaBand.astro";
import { buttonVariants } from "@workspace/ui/components/button";
import { Check } from "lucide-react";

const groups = [
  {
    title: "Data protection",
    items: [
      ["End-to-end encryption", "Encryption in transit and at rest across the platform."],
      ["PII redaction", "Optional redaction of sensitive fields before storage and logging."],
      ["Suppression & consent ledger", "Track suppression lists and a verifiable consent record."],
      ["Data residency", "Choose where data is stored to meet regional requirements."],
    ],
  },
  {
    title: "Access control",
    items: [
      ["Role-based access control", "Granular roles and team management for every action."],
      ["SSO / SAML", "Enterprise single sign-on with your identity provider."],
      ["IP allowlisting", "Restrict API and dashboard access to trusted networks."],
      ["Scope-based OAuth", "Per-account permission introspection and least-privilege scopes."],
    ],
  },
  {
    title: "Integrity & webhooks",
    items: [
      ["Signed webhooks", "Every outbound webhook is cryptographically signed."],
      ["Replay protection", "Timestamped signatures stop replayed requests."],
      ["Idempotency keys", "Prevent duplicate sends, even under retries and agent loops."],
      ["Full audit logs", "Every send — API, UI, or agent — is recorded for compliance."],
    ],
  },
];

const certs = ["SOC 2 Type II", "GDPR", "HIPAA-ready", "CAN-SPAM", "ISO 27001"];
---

<BaseLayout title="Security & Compliance" description="Encryption, PII redaction, RBAC, SSO, signed webhooks, audit logs, and SOC 2 / HIPAA / GDPR posture with data residency and a self-hosted option.">
  <PageHeader
    eyebrow="Security & compliance"
    title="Trust built into every send"
    lead="From encryption and PII redaction to scope-based OAuth, audit logs, and a self-hosted option — Renderical is built for compliance-heavy teams."
  />

  <section class="border-b py-8">
    <div class="mx-auto flex max-w-6xl flex-wrap justify-center gap-3 px-6">
      {certs.map((c) => (
        <span class="rounded-full border bg-card px-4 py-1.5 text-sm font-medium text-muted-foreground">{c}</span>
      ))}
    </div>
  </section>

  {groups.map((g, i) => (
    <section class={i % 2 === 1 ? "border-b bg-muted/30 py-14" : "border-b py-14"}>
      <div class="mx-auto max-w-6xl px-6">
        <h2 class="text-2xl font-semibold tracking-tight">{g.title}</h2>
        <div class="mt-8 grid gap-5 sm:grid-cols-2">
          {g.items.map(([t, d]) => (
            <div class="rounded-xl border bg-card p-5">
              <h3 class="font-semibold">{t}</h3>
              <p class="mt-1.5 text-sm text-muted-foreground">{d}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  ))}

  <section class="py-16">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <div>
          <p class="text-sm font-semibold text-primary">Deployment</p>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight">Run it your way</h2>
          <p class="mt-3 text-muted-foreground">
            Use the multi-region hosted cloud, or deploy self-hosted / on-prem for full data
            control. The compose API and stdio MCP server work identically in both.
          </p>
          <ul class="mt-5 space-y-3 text-sm">
            <li class="flex gap-3"><Check className="mt-0.5 size-4 shrink-0 text-primary" /><span>Multi-region delivery infrastructure</span></li>
            <li class="flex gap-3"><Check className="mt-0.5 size-4 shrink-0 text-primary" /><span>Provider failover for SMTP and push</span></li>
            <li class="flex gap-3"><Check className="mt-0.5 size-4 shrink-0 text-primary" /><span>Self-hosted / on-prem deployment option</span></li>
            <li class="flex gap-3"><Check className="mt-0.5 size-4 shrink-0 text-primary" /><span>Multi-tenant credential isolation</span></li>
          </ul>
        </div>
        <div>
          <p class="text-sm font-semibold text-primary">Reporting</p>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight">Prove it on demand</h2>
          <p class="mt-3 text-muted-foreground">
            Need our SOC 2 report, a DPA, or a security questionnaire completed? Our team turns
            these around quickly for evaluations and procurement.
          </p>
          <div class="mt-6">
            <a href="/contact" class={buttonVariants({ variant: "outline" })}>Request security docs</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBand title="Security questions? We have answers." text="Talk to our team about compliance, data residency, and self-hosted deployment." />
</BaseLayout>
