---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaBand from "../components/CtaBand.astro";
import { Faq } from "../components/Faq";
import { UseCases } from "../components/UseCases";
import { site } from "../config";
import { buttonVariants } from "@workspace/ui/components/button";
import {
  Layers,
  Split,
  ShieldCheck,
  SlidersHorizontal,
  RefreshCw,
  Bot,
  Clock,
  Workflow,
  BarChart3,
  Lock,
  Check,
  ArrowRight,
  MessageSquare,
  Mail,
  Smartphone,
  Bell,
  Globe,
  Webhook,
  Users,
  Gamepad2,
  MessageCircle,
  Phone,
  Send,
  Star,
  Quote,
} from "lucide-react";

const channelTiles = [
  { name: "Slack", icon: MessageSquare },
  { name: "Email", icon: Mail },
  { name: "Teams", icon: Users },
  { name: "Discord", icon: Gamepad2 },
  { name: "Push", icon: Smartphone },
  { name: "Web Push", icon: Globe },
  { name: "In-App", icon: Bell },
  { name: "Webhooks", icon: Webhook },
  { name: "SMS", icon: MessageCircle },
  { name: "WhatsApp", icon: Phone },
  { name: "Telegram", icon: Send },
];

const testimonials = [
  { quote: "We deleted four internal services and a preference center nobody wanted to own. One integration now handles every notification we send.", name: "Platform lead", role: "Growth-stage SaaS" },
  { quote: "Compose-once was the unlock. Our code stopped caring about channels — we just send, and Renderical figures out the rest.", name: "Staff engineer", role: "Fintech" },
  { quote: "The MCP server lets our agents notify users safely. Scoped, gated, audited — exactly what we needed to ship it.", name: "Head of AI", role: "Dev tools" },
];

const faqs = [
  { q: "What is Renderical?", a: "Unified notification infrastructure. You compose a message once and Renderical transforms and delivers it across every channel — Slack, email, Teams, Discord, push, in-app, webhooks, and SMS." },
  { q: "How is it different from an email or push service?", a: "Those cover one channel. Renderical normalizes every channel behind one API, adds routing rules, fallback chains, rate limiting, a preference center, and a native MCP server so a single integration replaces five tools." },
  { q: "Can AI agents send notifications?", a: "Yes. The native MCP server exposes sending, scheduling, and analytics as tools that agents call — authenticated with API keys, with preview and approval gates, idempotency, and full audit logging." },
  { q: "Can I self-host?", a: "Yes. The entire stack runs on Cloudflare Workers (D1, Queues, KV). Deploy to your own Cloudflare account and run the MCP server as a local stdio binary." },
];
---

<BaseLayout>
  <!-- Hero -->
  <section class="relative overflow-hidden border-b">
    <div class="pointer-events-none absolute inset-0 bg-dots mask-radial opacity-60"></div>
    <div class="pointer-events-none absolute left-1/2 top-0 -z-0 h-72 w-[42rem] -translate-x-1/2 rounded-full bg-primary/10 blur-3xl"></div>

    <div class="relative mx-auto max-w-6xl px-6 pt-20 pb-16 text-center">
      <a href="/mcp" class="inline-flex items-center gap-2 rounded-full border bg-background/70 px-3 py-1 text-xs font-medium text-muted-foreground backdrop-blur transition-colors hover:text-foreground">
        <span class="flex size-4 items-center justify-center rounded-full bg-primary/15 text-primary"><Bot className="size-2.5" /></span>
        New: native MCP server for AI agents
        <ArrowRight className="size-3" />
      </a>
      <h1 class="mx-auto mt-6 max-w-3xl text-4xl font-semibold tracking-tight text-balance sm:text-5xl lg:text-6xl">
        Send notifications everywhere from <span class="text-primary">one API</span>
      </h1>
      <p class="mx-auto mt-5 max-w-2xl text-lg text-muted-foreground text-pretty">
        {site.name} normalizes every channel behind one compose-once API — Slack, email, Teams,
        Discord, WhatsApp, Telegram, push, and in-app — with routing rules, fallback chains,
        rate limiting, and a built-in preference center. One integration replaces five.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <a href={site.signupUrl} class={buttonVariants({ size: "lg" })}>Start free</a>
        <a href="/developers" class={buttonVariants({ variant: "outline", size: "lg" })}>Read the docs</a>
      </div>
      <p class="mt-4 text-sm text-muted-foreground">Free tier · No credit card · Self-hosted option available</p>

      <!-- Product window mock -->
      <div class="relative mx-auto mt-16 max-w-4xl text-left">
        <div class="overflow-hidden rounded-xl border bg-card shadow-sm">
          <div class="flex items-center gap-2 border-b bg-muted/40 px-4 py-3">
            <span class="size-3 rounded-full bg-muted-foreground/20"></span>
            <span class="size-3 rounded-full bg-muted-foreground/20"></span>
            <span class="size-3 rounded-full bg-muted-foreground/20"></span>
            <span class="ml-2 font-mono text-xs text-muted-foreground">renderical · compose</span>
          </div>
          <div class="grid gap-0 md:grid-cols-2 md:divide-x">
            <!-- Compose -->
            <div class="p-6">
              <p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Compose once</p>
              <div class="mt-3 rounded-lg border bg-background p-4">
                <p class="text-sm font-semibold">Your invoice is paid 🎉</p>
                <p class="mt-1 text-sm text-muted-foreground">Thanks, Maria — your $240.00 payment was received.</p>
                <span class={`mt-3 ${buttonVariants({ size: "xs" })}`}>View receipt</span>
              </div>
              <div class="mt-4 rounded-lg bg-muted/60 p-3 font-mono text-xs text-muted-foreground">
                template: <span class="text-primary">"invoice.paid"</span><br />
                channels: <span class="text-foreground">[push, email, sms]</span>
              </div>
            </div>
            <!-- Delivery -->
            <div class="p-6">
              <p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground">Delivered, per channel</p>
              <div class="mt-3 divide-y">
                {[
                  [MessageSquare, "Slack", "Delivered", "bg-green-500/10 text-green-600 dark:text-green-500"],
                  [Mail, "Email", "Opened", "bg-primary/10 text-primary"],
                  [Smartphone, "Push", "Delivered", "bg-green-500/10 text-green-600 dark:text-green-500"],
                  [MessageCircle, "SMS", "Fallback ready", "bg-muted text-muted-foreground"],
                ].map(([Icon, name, status, cls]) => (
                  <div class="flex items-center justify-between py-3">
                    <span class="flex items-center gap-2.5 text-sm font-medium">
                      <span class="flex size-7 items-center justify-center rounded-md border bg-muted/50"><Icon className="size-3.5" /></span>
                      {name}
                    </span>
                    <span class={`rounded-full px-2.5 py-1 text-xs font-medium ${cls}`}>{status}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Trust strip -->
  <section class="border-b bg-muted/30">
    <div class="mx-auto max-w-6xl px-6 py-10">
      <p class="text-center text-xs font-medium uppercase tracking-wider text-muted-foreground">One API for every channel teams ship on</p>
      <div class="mt-6 flex flex-wrap items-center justify-center gap-x-10 gap-y-3 text-base font-semibold text-muted-foreground/70">
        <span>Slack</span><span>Email</span><span>Teams</span><span>Discord</span>
        <span>WhatsApp</span><span>Telegram</span><span>APNs/FCM</span><span>Webhooks</span>
      </div>
    </div>
  </section>

  <!-- Bento grid -->
  <section class="py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-sm font-semibold text-primary">The platform</p>
        <h2 class="mt-2 text-3xl font-semibold tracking-tight sm:text-4xl">Everything the five tools did — in one</h2>
        <p class="mt-3 text-muted-foreground">Delivery, routing rules, rate limiting, compliance, and agentic sending, behind a single API.</p>
      </div>

      <div class="mt-12 grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        <!-- A: compose once (wide) -->
        <div class="group rounded-2xl border bg-card p-6 transition hover:border-foreground/20 lg:col-span-2">
          <div class="flex items-center gap-2.5">
            <span class="flex size-9 items-center justify-center rounded-lg border bg-muted/50"><Layers className="size-5" /></span>
            <h3 class="font-semibold">Compose once, transform everywhere</h3>
          </div>
          <p class="mt-2 max-w-md text-sm text-muted-foreground">One normalized payload, automatically rendered into Slack blocks, HTML email, Teams cards, Discord embeds, and push.</p>
          <div class="mt-5 flex flex-wrap gap-2">
            {channelTiles.map((c) => (
              <span class="inline-flex items-center gap-1.5 rounded-lg border bg-background px-2.5 py-1.5 text-xs font-medium transition group-hover:border-foreground/15">
                <c.icon className="size-3.5 text-muted-foreground" />{c.name}
              </span>
            ))}
          </div>
        </div>

        <!-- B: MCP (tall) -->
        <div class="group rounded-2xl border bg-card p-6 transition hover:border-foreground/20 lg:row-span-2">
          <div class="flex items-center gap-2.5">
            <span class="flex size-9 items-center justify-center rounded-lg border bg-muted/50"><Bot className="size-5" /></span>
            <h3 class="font-semibold">Native MCP server</h3>
          </div>
          <p class="mt-2 text-sm text-muted-foreground">Agents compose, schedule, and send — within granted scopes, preview-gated and audited.</p>
          <div class="mt-5 rounded-lg bg-muted/60 p-4 font-mono text-xs leading-relaxed text-muted-foreground">
            <span class="text-muted-foreground/60"># agent tool call</span><br />
            <span class="text-foreground">send_notification</span>(<br />
            &nbsp;&nbsp;recipient=<span class="text-primary">"u_8a21"</span>,<br />
            &nbsp;&nbsp;prefer=<span class="text-primary">"preferred"</span>,<br />
            &nbsp;&nbsp;fallback=<span class="text-foreground">True</span>,<br />
            )<br /><br />
            <span class="text-muted-foreground/60"># ✓ scope-checked</span><br />
            <span class="text-muted-foreground/60"># ✓ approval gate</span><br />
            <span class="text-muted-foreground/60"># ✓ audited</span>
          </div>
          <a href="/mcp" class="mt-5 inline-flex items-center gap-1 text-sm font-medium text-primary hover:underline">Explore the MCP server <ArrowRight className="size-3.5" /></a>
        </div>

        <!-- C: fallback -->
        <div class="group rounded-2xl border bg-card p-6 transition hover:border-foreground/20">
          <div class="flex items-center gap-2.5">
            <span class="flex size-9 items-center justify-center rounded-lg border bg-muted/50"><Split className="size-5" /></span>
            <h3 class="font-semibold">Fallback chains</h3>
          </div>
          <p class="mt-2 text-sm text-muted-foreground">Try the best channel, fall back automatically until one delivers.</p>
          <div class="mt-4 flex items-center gap-2 text-xs font-medium">
            <span class="rounded-md border bg-background px-2 py-1">Push</span>
            <ArrowRight className="size-3.5 text-muted-foreground" />
            <span class="rounded-md border bg-background px-2 py-1">Email</span>
            <ArrowRight className="size-3.5 text-muted-foreground" />
            <span class="rounded-md border bg-background px-2 py-1">SMS</span>
          </div>
        </div>

        <!-- D: preferences -->
        <div class="group rounded-2xl border bg-card p-6 transition hover:border-foreground/20">
          <div class="flex items-center gap-2.5">
            <span class="flex size-9 items-center justify-center rounded-lg border bg-muted/50"><SlidersHorizontal className="size-5" /></span>
            <h3 class="font-semibold">Preference center</h3>
          </div>
          <p class="mt-2 text-sm text-muted-foreground">Per-channel opt-in, digests, and compliant unsubscribe.</p>
          <div class="mt-4 space-y-2.5">
            {[["Product updates", true], ["Weekly digest", true], ["Marketing", false]].map(([label, on]) => (
              <div class="flex items-center justify-between text-sm">
                <span class="text-muted-foreground">{label}</span>
                <span class={`relative h-5 w-9 rounded-full transition ${on ? "bg-primary" : "bg-muted-foreground/25"}`}>
                  <span class={`absolute top-0.5 size-4 rounded-full bg-white transition-all ${on ? "right-0.5" : "left-0.5"}`}></span>
                </span>
              </div>
            ))}
          </div>
        </div>
      </div>

      <div class="mt-8 text-center">
        <a href="/features" class={buttonVariants({ variant: "outline" })}>See all features</a>
      </div>
    </div>
  </section>

  <!-- Use cases (interactive tabs) -->
  <section class="border-t bg-muted/30 py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-sm font-semibold text-primary">Use cases</p>
        <h2 class="mt-2 text-3xl font-semibold tracking-tight sm:text-4xl">Built for every message you send</h2>
        <p class="mt-3 text-muted-foreground">From OTPs to AI agents — the same compose-once API, routed the way each message needs.</p>
      </div>
      <div class="mt-10">
        <UseCases client:visible />
      </div>
    </div>
  </section>

  <!-- Channels -->
  <section class="py-20">
    <div class="mx-auto max-w-6xl px-6 text-center">
      <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">Connect once. Reach anywhere.</h2>
      <p class="mx-auto mt-3 max-w-2xl text-muted-foreground">Broadcast, targeted, and transactional sending with rate-aware throttling and timezone-aware scheduling.</p>
      <div class="mx-auto mt-10 grid max-w-3xl grid-cols-3 gap-3 sm:grid-cols-3 md:grid-cols-3">
        {channelTiles.map((c) => (
          <div class="flex flex-col items-center gap-2 rounded-xl border bg-card px-3 py-5 transition hover:border-foreground/20">
            <span class="flex size-10 items-center justify-center rounded-lg border bg-muted/50"><c.icon className="size-5" /></span>
            <span class="text-sm font-medium">{c.name}</span>
          </div>
        ))}
      </div>
      <div class="mt-10">
        <a href="/channels" class={buttonVariants({ variant: "outline" })}>Explore channels</a>
      </div>
    </div>
  </section>

  <!-- How it works -->
  <section class="border-t bg-muted/30 py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">From event to delivered in four steps</h2>
      </div>
      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          [Lock, "Connect your channels", "Add a channel connection with an API key or bot token. Credentials are AES-GCM encrypted at rest."],
          [Layers, "Build a template", "Design once in the visual builder with variables and localization. Preview every channel live."],
          [Clock, "Send or schedule", "Call the API, fire a webhook, or let an agent invoke an MCP tool. Add send-at, quiet hours, and fallback."],
          [BarChart3, "Track & optimize", "Watch delivery, opens, clicks, and cost per channel. Get alerted on anomalies and bounces."],
        ].map(([Icon, title, text], i) => (
          <div class="relative rounded-xl border bg-card p-6">
            <div class="flex items-center gap-3">
              <span class="flex size-8 items-center justify-center rounded-lg bg-primary text-sm font-semibold text-primary-foreground">{i + 1}</span>
              <Icon className="size-5 text-muted-foreground" />
            </div>
            <h3 class="mt-4 font-semibold">{title}</h3>
            <p class="mt-1.5 text-sm text-muted-foreground">{text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats band -->
  <section class="py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="rounded-2xl border bg-primary/5 px-6 py-12">
        <div class="grid gap-8 text-center sm:grid-cols-2 lg:grid-cols-4">
          {[["11+", "Channels, one API"], ["99.99%", "Delivery uptime SLA"], ["9", "Native MCP tools"], ["Edge-native", "Cloudflare Workers"]].map(([num, lbl]) => (
            <div>
              <div class="text-4xl font-semibold tracking-tight text-primary">{num}</div>
              <div class="mt-1 text-sm text-muted-foreground">{lbl}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section class="border-t bg-muted/30 py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <div class="flex justify-center gap-1 text-primary">
          {[0, 1, 2, 3, 4].map(() => <Star className="size-4 fill-current" />)}
        </div>
        <h2 class="mt-4 text-3xl font-semibold tracking-tight sm:text-4xl">Teams ship faster on Renderical</h2>
      </div>
      <div class="mt-12 grid gap-5 md:grid-cols-3">
        {testimonials.map((t) => (
          <figure class="flex flex-col rounded-xl border bg-card p-6">
            <Quote className="size-6 text-primary/40" />
            <blockquote class="mt-3 flex-1 text-sm leading-relaxed text-foreground">“{t.quote}”</blockquote>
            <figcaption class="mt-5 border-t pt-4 text-sm">
              <span class="font-medium">{t.name}</span>
              <span class="text-muted-foreground"> · {t.role}</span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto mb-10 max-w-2xl text-center">
        <h2 class="text-3xl font-semibold tracking-tight sm:text-4xl">Questions, answered</h2>
      </div>
      <Faq items={faqs} client:visible />
    </div>
  </section>

  <CtaBand />
</BaseLayout>
