---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHeader from "../components/PageHeader.astro";
import CtaBand from "../components/CtaBand.astro";
import { buttonVariants } from "@workspace/ui/components/button";
import { Code2, Boxes, Webhook, FlaskConical, Terminal, ScrollText, Check } from "lucide-react";

const dx = [
  { icon: Code2, title: "REST API", text: "Typed REST API with consistent error envelopes, keyset pagination, and idempotency keys." },
  { icon: Boxes, title: "TypeScript SDK", text: "Typed JS/TS client with send(), preview(), listDeliveries(), and key management built in." },
  { icon: Webhook, title: "Webhook ingestion", text: "Drive sends from any event source with signed delivery webhooks." },
  { icon: FlaskConical, title: "Sandbox / test mode", text: "Pass a test-mode API key or the X-Renderical-Sandbox header to get per-channel previews without real delivery." },
  { icon: Terminal, title: "CLI", text: "Send, preview, tail logs, and manage keys directly from your terminal via the @renderical/cli package." },
  { icon: ScrollText, title: "Request log & inspector", text: "Every API call is logged with method, path, status, and latency — debug any delivery in seconds." },
];
---

<BaseLayout title="Developers" description="REST API, TypeScript SDK, CLI, webhook ingestion, sandbox mode, and a native MCP server — built for developer experience.">
  <PageHeader
    eyebrow="Developers"
    title="Built for the way you ship"
    lead="TypeScript SDK, REST API, a CLI, sandbox mode, and a native MCP server. Send your first notification in minutes."
  />

  <!-- Quickstart -->
  <section class="py-16" id="api">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div>
          <p class="text-sm font-semibold text-primary">Quickstart</p>
          <h2 class="mt-2 text-3xl font-semibold tracking-tight">Send in minutes</h2>
          <p class="mt-4 text-muted-foreground">
            Install the SDK, set your API key, and call <code class="rounded bg-muted px-1.5 py-0.5 text-sm">send</code>.
            Channels, fallback, and idempotency are all part of one payload.
          </p>
          <ul class="mt-6 space-y-3 text-sm">
            <li class="flex gap-3"><Check className="mt-0.5 size-4 shrink-0 text-primary" /><span>API keys: live and test modes</span></li>
            <li class="flex gap-3"><Check className="mt-0.5 size-4 shrink-0 text-primary" /><span>Sandbox mode: per-channel previews without real delivery</span></li>
            <li class="flex gap-3"><Check className="mt-0.5 size-4 shrink-0 text-primary" /><span>Delivery status via polling or webhook callbacks</span></li>
          </ul>
        </div>
        <div class="rounded-xl border bg-card p-5 font-mono text-sm leading-relaxed">
          <pre class="overflow-x-auto text-muted-foreground"><code><span class="text-muted-foreground/60">$ npm install @renderical/sdk</span>

import {'{'} createRendericalClient {'}'} from <span class="text-primary">"@renderical/sdk"</span>;
const rc = <span class="text-foreground">createRendericalClient</span>({'{'}
  apiKey: process.env.<span class="text-primary">RENDERICAL_API_KEY</span>,
{'}'});

await rc.<span class="text-foreground">send</span>({'{'}
  to: <span class="text-primary">"user@example.com"</span>,
  template: <span class="text-primary">"welcome"</span>,
  channels: [<span class="text-primary">"email"</span>, <span class="text-primary">"push"</span>],
{'}'});</code></pre>
        </div>
      </div>
    </div>
  </section>

  <!-- DX grid -->
  <section class="border-t bg-muted/30 py-16" id="sdks">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-semibold tracking-tight">Everything you need to integrate</h2>
      </div>
      <div class="mt-10 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {dx.map((d) => (
          <div class="rounded-xl border bg-card p-6">
            <div class="flex size-9 items-center justify-center rounded-lg border bg-muted/50">
              <d.icon className="size-5" />
            </div>
            <h3 class="mt-4 font-semibold">{d.title}</h3>
            <p class="mt-1.5 text-sm text-muted-foreground">{d.text}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MCP -->
  <section class="py-16">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div class="order-2 lg:order-1 rounded-xl border bg-card p-5 font-mono text-sm leading-relaxed">
          <pre class="overflow-x-auto text-muted-foreground"><code><span class="text-muted-foreground/60">// claude_desktop_config.json</span>
{'{'}
  <span class="text-foreground">"mcpServers"</span>: {'{'}
    <span class="text-foreground">"renderical"</span>: {'{'}
      <span class="text-foreground">"type"</span>: <span class="text-primary">"http"</span>,
      <span class="text-foreground">"url"</span>: <span class="text-primary">"https://your-worker.workers.dev/mcp"</span>,
      <span class="text-foreground">"headers"</span>: {'{'}
        <span class="text-foreground">"Authorization"</span>: <span class="text-primary">"Bearer rk_live_..."</span>
      {'}'}
    {'}'}
  {'}'}
{'}'}</code></pre>
        </div>
        <div class="order-1 lg:order-2">
          <p class="text-sm font-semibold text-primary">MCP server</p>
          <h2 class="mt-2 text-3xl font-semibold tracking-tight">Wire up agents in seconds</h2>
          <p class="mt-4 text-muted-foreground">
            Point any MCP client at the hosted endpoint, authenticate with your API key, and your agent can
            send, schedule, and query analytics. Prefer local? Run the stdio binary with <code class="rounded bg-muted px-1.5 py-0.5 text-sm">RENDERICAL_API_KEY</code> for self-hosted and dev setups.
          </p>
          <div class="mt-6">
            <a href="/mcp" class={buttonVariants({ variant: "outline" })}>MCP server details</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBand title="Get your API key" text="Create a free account, grab your key, and ship your first multi-channel notification today." />
</BaseLayout>
