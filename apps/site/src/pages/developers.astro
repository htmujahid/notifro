---
import BaseLayout from "../layouts/BaseLayout.astro";
import CtaBand from "../components/CtaBand.astro";

const dx = [
  ["REST & GraphQL APIs", "First-class REST and GraphQL, fully typed and documented."],
  ["SDKs", "Native SDKs for JavaScript/TypeScript, Python, Go, Ruby, and PHP."],
  ["Webhook ingestion", "Drive sends from any event source with signed webhooks."],
  ["Sandbox / test mode", "Safe test sends with per-channel message previews."],
  ["CLI", "Test, preview, and tail logs from your terminal."],
  ["API logs & inspector", "Detailed request logs to debug any delivery."],
];
---

<BaseLayout title="Developers" description="REST & GraphQL APIs, SDKs for major languages, a CLI, webhook ingestion, sandbox mode, and a native MCP server — built for developer experience.">
  <section class="hero" style="padding-bottom:48px">
    <div class="container">
      <span class="eyebrow">Developers</span>
      <h1>Built for the way you ship</h1>
      <p class="lead mx-auto">Typed SDKs, REST and GraphQL, a CLI, sandbox mode, and a native
      MCP server. Send your first notification in under five minutes.</p>
    </div>
  </section>

  <!-- Quickstart -->
  <section style="padding-top:24px" id="api">
    <div class="container">
      <div class="split">
        <div>
          <span class="eyebrow">Quickstart</span>
          <h2>Send in three lines</h2>
          <p>Install the SDK, set your API key, and call <code>send</code>. Channels, fallback,
          and idempotency are all part of one payload.</p>
          <ul class="checklist" style="margin-top:16px">
            <li><span class="tick">✓</span><span>Idempotency keys to prevent duplicates</span></li>
            <li><span class="tick">✓</span><span>Per-channel previews in sandbox mode</span></li>
            <li><span class="tick">✓</span><span>Delivery status via polling or webhooks</span></li>
          </ul>
        </div>
        <div class="split-media">
          <div class="code">
            <div class="code-head"><span></span><span></span><span></span></div>
            <span class="c-com">$ npm install @renderical/node</span><br /><br />
            <span class="c-key">import</span> &#123; Renderical &#125; <span class="c-key">from</span> <span class="c-str">"@renderical/node"</span>;<br />
            <span class="c-key">const</span> rc = <span class="c-key">new</span> <span class="c-fn">Renderical</span>(process.env.RC_KEY);<br /><br />
            <span class="c-key">await</span> rc.<span class="c-fn">send</span>(&#123;<br />
            &nbsp;&nbsp;to: <span class="c-str">"u_8a21"</span>,<br />
            &nbsp;&nbsp;template: <span class="c-str">"welcome"</span>,<br />
            &nbsp;&nbsp;channels: [<span class="c-str">"email"</span>, <span class="c-str">"push"</span>],<br />
            &nbsp;&nbsp;fallback: <span class="c-key">true</span>,<br />
            &#125;);
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DX grid -->
  <section class="band-dark" id="sdks">
    <div class="container">
      <div class="section-head">
        <span class="eyebrow">Developer experience</span>
        <h2>Everything you need to integrate</h2>
      </div>
      <div class="grid grid-3">
        {dx.map(([t, d]) => (
          <div class="card" style="background:rgba(255,255,255,0.04);border-color:rgba(255,255,255,0.1)">
            <h3 style="font-size:1.05rem">{t}</h3>
            <p style="margin-bottom:0">{d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MCP -->
  <section>
    <div class="container">
      <div class="split reverse">
        <div class="split-media">
          <div class="code">
            <div class="code-head"><span></span><span></span><span></span></div>
            <span class="c-com">// claude_desktop_config.json</span><br />
            &#123;<br />
            &nbsp;&nbsp;<span class="c-key">"mcpServers"</span>: &#123;<br />
            &nbsp;&nbsp;&nbsp;&nbsp;<span class="c-key">"renderical"</span>: &#123;<br />
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="c-key">"url"</span>: <span class="c-str">"https://mcp.renderical.com"</span>,<br />
            &nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;<span class="c-key">"auth"</span>: <span class="c-str">"oauth"</span><br />
            &nbsp;&nbsp;&nbsp;&nbsp;&#125;<br />
            &nbsp;&nbsp;&#125;<br />
            &#125;
          </div>
        </div>
        <div>
          <span class="eyebrow">MCP server</span>
          <h2>Wire up agents in seconds</h2>
          <p>Point any MCP client at the hosted server, authenticate with OAuth, and your agent
          can send, schedule, and query analytics within granted scopes. Prefer local? Run the
          stdio server for self-hosted and dev.</p>
          <div style="margin-top:20px">
            <a class="btn btn-primary" href="/mcp">MCP server details →</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <CtaBand title="Get your API key" text="Create a free account, grab your key, and ship your first multi-channel notification today." />
</BaseLayout>
