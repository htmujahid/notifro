{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node", "vite/client"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": true,
    "sourceMap": true,
    "noEmit": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "paths": {
      "@workspace/app/*": ["../../packages/app/src/*"],
      "@workspace/views/*": ["../../packages/views/src/*"]
    }
  },
  "include": ["electron", "src", "forge.config.ts", "forge.env.d.ts", "vite.*.config.ts"]
}
