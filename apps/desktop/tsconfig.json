{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node", "vite/client"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "strict": true,
    "sourceMap": true,
    "noEmit": true,
    "moduleResolution": "bundler",
    "resolveJsonModule": true
  },
  "include": ["electron", "src", "forge.config.ts", "forge.env.d.ts", "vite.*.config.ts"]
}
