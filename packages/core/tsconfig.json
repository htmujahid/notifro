{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "paths": {
      "@notifro/core/*": ["./src/*"],
      "@notifro/api-client/*": ["../api-client/src/*"],
      "@notifro/app/*": ["../app/src/*"],
      "@notifro/ui/*": ["../ui/src/*"],
      "@notifro/ui-primitives/*": ["../ui-primitives/src/*"]
    }
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
