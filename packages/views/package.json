    "format": "prettier --write \"**/*.{ts,tsx}\"",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@renderical/api-client": "workspace:*",
    "@renderical/core": "workspace:*",
    "@renderical/ui": "workspace:*",
