{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "paths": {
      "@notifro/views/*": ["./src/*"],
      "@notifro/core/*": ["../core/src/*"],
      "@notifro/ui/*": ["../ui/src/*"]
    }
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
