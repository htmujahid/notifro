{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@notifro/sdk": ["../sdk/src/index.ts"],
      "@notifro/sdk/*": ["../sdk/src/*"],
      "@notifro/api-client/*": ["../api-client/src/*"]
    }
  },
  "include": ["."],
  "exclude": ["node_modules", "dist"]
}
